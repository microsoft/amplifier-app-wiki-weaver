// wiki-weaver-inner.dot -- Integrate ONE source into the wiki, until coherent.
//
// The inner attractor loop: ingest -> validate (structural, code) -> assess
// (quality, LLM, against the shared rubric) -> converged? -> (refine) feedback
// -> loop_restart. Specialized clone of convergence-factory.dot.
//
// This is the THINNEST provable slice. The outer corpus-sweep (foreach source)
// wraps this as a folder sub-pipeline once this is proven on real sources.
//
// Required context variables (inject via parent context.* or --context):
//   $source_path   -- the raw source article to integrate this cycle
//   $wiki_dir      -- the wiki directory (persistent artifact, survives loop_restart)
//   $schema_path   -- path to SCHEMA.md (the page contract)
//   $rubric_path   -- path to the eval rubric.md (assess uses Tier-2 criteria)
//   $validate_cmd  -- structural validator command (validate_wiki.py $wiki_dir)
//   $max_cycles    -- hard iteration bound (LLM-judged loops MUST be bounded)
//
// State lives on the FILESYSTEM ($wiki_dir, .ai/feedback/, .ai/assessment.md)
// because loop_restart resets context.

digraph wiki_weaver_inner {
    graph [
        goal="Integrate one source into a coherent, link-valid, contradiction-flagging wiki",
        default_max_retry="4",
        default_fidelity="compact"
    ]

    start [shape=Mdiamond, label="Start"]

    // INGEST (LLM): read source + existing wiki + prior feedback + schema,
    // then create/update concept/entity pages with [[links]], frontmatter,
    // and surface contradictions per the schema. Updates existing pages,
    // never creates per-source duplicates.
    ingest [
        label="Ingest Source",
        prompt="You are weaving one source into a persistent knowledge wiki.\n\nSource to integrate: $source_path\nWiki directory: $wiki_dir\nSchema (the page contract you MUST follow): $schema_path\n\nFirst read $schema_path. Then read the CURRENT state of $wiki_dir (every existing page) and check .ai/feedback/ for refinement guidance from prior iterations.\n\nThen integrate the source:\n- Update EXISTING pages when the source discusses a concept already present (one page per concept; never create a near-duplicate).\n- Create new concept/entity pages for genuinely new concepts, with valid frontmatter (title, type, sources, last_updated).\n- Add [[wikilinks]] between related pages; every link must resolve to a page (create a stub if needed).\n- When the source DISAGREES with an existing page (different claim, or a different number for the same fact), DO NOT average or overwrite -- add/extend an '## Open tensions' section citing both sides with sources.\n- Maintain index.md and overview.md.\n\nWrite all changes under $wiki_dir now."
    ]

    // VALIDATE (code, deterministic): the Tier-1 structural graders.
    // Non-zero exit forces the loop to treat the wiki as not-yet-valid.
    validate [
        shape=parallelogram,
        label="Validate Structure",
        tool_command="$validate_cmd"
    ]

    // ASSESS (LLM): judge against the shared rubric Tier-2. MUST set
    // preferred_label=converged or =refine.
    assess [
        label="Assess Quality",
        prompt="You are assessing whether the wiki at $wiki_dir has correctly integrated the source $source_path.\n\nApply the Tier-2 quality rubric in $rubric_path: synthesis (merged, not dumped), contradiction-handling (tensions surfaced not averaged), merge-correctness (distinct gaps kept distinct), no-confabulation (no claims absent from sources; no strawman asserted), provenance-fidelity.\n\nReview the structural validation results and the wiki pages touched.\n\nIf every rubric dimension is >= 4/5: return outcome 'converged'.\nOtherwise: return outcome 'refine'.\n\nWrite a brief assessment (per-dimension score + evidence) to .ai/assessment.md before returning."
    ]

    check [shape=diamond, label="Converged?"]

    // FEEDBACK (LLM): only on refine. Targeted guidance for next cycle.
    feedback [
        label="Write Feedback",
        prompt="Write targeted refinement guidance for the next ingest cycle.\n\nRead .ai/assessment.md and any prior files in .ai/feedback/.\nWrite a new file to .ai/feedback/ using the Pyramid Summary pattern:\n  1. Key finding (1 sentence) -- the most important gap.\n  2. What to change (3-5 specific, actionable bullets) -- e.g. which pages to merge, which tension to surface, which broken link to fix.\n  3. Why it matters (1-2 sentences) -- how it moves toward a coherent wiki.\nFocus only on the delta needed to converge."
    ]

    done [shape=Msquare, label="Done"]

    start -> ingest
    ingest -> validate
    validate -> assess
    assess -> check

    check -> done     [label="converged", condition="context.preferred_label=converged"]
    check -> feedback [label="refine",    condition="context.preferred_label=refine"]

    feedback -> ingest [loop_restart="true"]
}
