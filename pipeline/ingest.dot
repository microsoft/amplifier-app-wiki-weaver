// ingest.dot -- Full inbox DRAIN loop via synthesize.dot.
//
// Drains the _inbox/ in a single run: picks one source, synthesizes it,
// tamper-checks it, archives or fails it, then loops back to setup until
// the inbox is empty.
//
// Compile-time tokens substituted by run_ingest() before handing to the engine:
//   $setup_cmd         -- absolute path command to cli/ingest_setup.py
//   $synthesize_dot    -- absolute path to pipeline/synthesize.dot
//   $max_drain_iters   -- safety bound (generous multiple of inbox size);
//                         if this limit trips the engine fails loud, which is
//                         the correct behaviour -- a bug would spin forever
//                         otherwise.
//   $clear_synthesize_cmd -- rm -f for the child synthesize checkpoint
//
// Context keys produced by the setup node (via parse_json="true") and consumed
// by subsequent nodes via $var references:
//   has_source, source_path, source_id, wiki_dir, validation_report,
//   schema_path, convergence_rubric, max_cycles,
//   normalize_cmd, footnotes_cmd, validate_cmd,
//   archive_cmd, fail_cmd, tamper_check_cmd
//
// Drain-loop semantics:
//   setup emits has_source=false  -> done (inbox drained, clean exit)
//   setup emits has_source=true   -> synthesize -> tamper_check -> archive or fail_handler
//   tamper detected               -> fail_handler (source -> _failed/, undo tamper)
//   archive/fail_handler          -> setup (loop_restart="true")

digraph ingest {
    graph [
        goal="Drain the inbox: ingest all sources via synthesize.dot",
        default_max_retry="$max_drain_iters"
    ]

    start [shape=Mdiamond, label="Start"]

    // SETUP (deterministic tool): pick next inbox source, assign stable id,
    // snapshot process state (for tamper detection), emit JSON context keys for
    // synthesize.dot and the archive/fail/tamper_check commands.
    // Emits has_source=false (inbox empty) or has_source=true (source ready).
    // ALWAYS exits 0 -- inbox empty is the normal drain-complete signal.
    setup [
        shape=parallelogram,
        label="Setup: pick source + assign id",
        tool_command="$setup_cmd",
        parse_json="true"
    ]

    // CLEAR_SYNTHESIZE_STATE: delete the subgraph checkpoint left by the
    // previous loop iteration so the child pipeline always starts fresh.
    //
    // Why: PipelineHandler creates child logs at {run_dir}/subgraph_{node.id}.
    // The directory is reused across loop iterations (exist_ok=True), so the
    // checkpoint written by iteration 1 is found by iteration 2's child engine,
    // which fingerprint-matches synthesize.dot (unchanged), restores stale
    // context (source_id=1), and exits immediately without doing real work.
    // This rm -f runs before every run_synthesize invocation; -f means exit 0
    // on first iteration when the file does not yet exist.
    // $clear_synthesize_cmd is substituted at compile-time by run_ingest().
    clear_synthesize_state [
        shape=parallelogram,
        label="Clear synthesize state",
        tool_command="$clear_synthesize_cmd"
    ]

    // RUN_SYNTHESIZE (folder sub-pipeline): runs synthesize.dot with the
    // context keys produced by the setup node. Child inherits context clone,
    // so $source_path/$wiki_dir/etc. resolve directly inside the child.
    run_synthesize [
        shape=folder,
        label="Synthesize source",
        dot_file="$synthesize_dot"
    ]

    // TAMPER_CHECK (deterministic tool): reads the before-synthesis snapshot
    // written by setup (path embedded in $tamper_check_cmd), calls
    // _detect_and_undo_tamper from cli/lib.py, and emits {"tampered":"false"}
    // or {"tampered":"true"}.
    //
    // Invariant: the ledger (.processed.jsonl) and _archive/ are CLI-exclusive.
    // The LLM is FORBIDDEN from writing either during synthesis.  If it did,
    // _detect_and_undo_tamper undoes the damage (truncates fabricated ledger
    // lines, returns falsely-archived files to the inbox), prints a loud error
    // to stderr, and emits tampered=true so the router sends this source to
    // _failed/ instead of _archive/.
    //
    // Only fires on the converged path (outcome=success from run_synthesize).
    // Non-converged sources go directly to fail_handler -- tamper check is
    // irrelevant when synthesis did not complete.
    tamper_check [
        shape=parallelogram,
        label="Tamper check",
        tool_command="$tamper_check_cmd",
        parse_json="true"
    ]

    // ARCHIVE (deterministic tool): move source -> _archive/, append ledger,
    // mark ingested in .sources.json. Uses $archive_cmd from context (set by
    // setup for the current source).
    archive [
        shape=parallelogram,
        label="Archive source",
        tool_command="$archive_cmd"
    ]

    // FAIL_HANDLER (deterministic tool): move non-converged or tampered source
    // -> _failed/ so the inbox shrinks and the drain loop continues cleanly.
    // Uses $fail_cmd from context (set by setup for the current source).
    fail_handler [
        shape=parallelogram,
        label="Route to _failed/",
        tool_command="$fail_cmd"
    ]

    done [shape=Msquare, label="Done"]

    start -> setup

    // SETUP routes EXHAUSTIVELY (no dead-end).
    // Conditional edges are tried first; the single unconditional fallback
    // (else) is the safety net for any unexpected state.
    setup -> done                   [label="inbox empty",          condition="context.has_source=false"]
    setup -> clear_synthesize_state [label="source ready",         condition="context.has_source=true"]
    setup -> done                   [label="else (unexpected -> done)"]

    clear_synthesize_state -> run_synthesize

    // RUN_SYNTHESIZE routes:
    //   converged  -> tamper_check (verify LLM did not write process state)
    //   everything else -> fail_handler (non-convergence, error, unset)
    // The unconditional fallback is the fail-safe direction -- more drain,
    // never premature done.
    //
    // NOTE on condition value: the assess node in synthesize.dot emits
    // {"preferred_label": "converged"} via report_outcome when it converges.
    // The engine propagates this as the folder node's preferred_label, and
    // conditions.py _resolve_key("outcome") returns preferred_label if set,
    // falling back to status.value only when preferred_label is null.
    // Therefore the condition must match "converged" (the actual resolved
    // value), NOT "outcome=success" (which is shadowed by preferred_label).
    run_synthesize -> tamper_check [label="converged",           condition="outcome=converged"]
    run_synthesize -> fail_handler [label="else (non-converged)"]

    // TAMPER_CHECK routes EXHAUSTIVELY.
    // Clean path: archive (write process state, then loop back).
    // Tamper path: fail_handler (source goes to _failed/, tamper already undone).
    tamper_check -> archive      [label="clean",               condition="context.tampered=false"]
    tamper_check -> fail_handler [label="tampered",            condition="context.tampered=true"]
    tamper_check -> fail_handler [label="else (unexpected -> fail)"]

    // Loop back to drain the next source.
    // Both edges use loop_restart="true" so the engine restarts the outer
    // loop counter cleanly on each successful or failed source.
    archive      -> setup [loop_restart="true"]
    fail_handler -> setup [loop_restart="true"]
}
